{
	"name": "restic-subset-calculator",
	"image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": true,
			"makeUiDefault": true
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"charliermarsh.ruff",
				"ms-python.python",
				"pdm-project.pdm-vscode"
			]
		}
	},
	"postCreateCommand": "sudo apt-get update && sudo apt-get install -y restic && pip install pdm && pdm install"
}
